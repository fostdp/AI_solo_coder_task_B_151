# ============================================
# 古代水转翻车链传动动力学仿真系统
# 环境变量配置模板
# 使用方法：复制为 .env 文件，修改需要定制的参数
# ============================================

# 时区
TZ=Asia/Shanghai

# ============================================
# 数据库配置 - TimescaleDB
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=waterwheel_simulation
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MAX=20
DB_POOL_MIN=5

# ============================================
# MQTT Broker 配置 - Eclipse Mosquitto
# ============================================
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=admin
MQTT_PASSWORD=admin
MQTT_TOPIC=waterwheel/sensor

# ============================================
# 后端服务配置
# ============================================
BACKEND_PORT=8080
LOG_LEVEL=INFO
JAVA_HEAP=512
JAVA_HEAP_MIN=256

# ============================================
# 前端服务配置
# ============================================
FRONTEND_PORT=80

# ============================================
# 传感器模拟器配置
# ============================================
SIMULATOR_INTERVAL=5
# 链速倍率：0.5 - 3.0
CHAIN_SPEED=1.0
# 刮板形状：arc(弧形) / flat(平板) / trapezoid(梯形)
SCRAPER_SHAPE=flat

# ============================================
# Grafana 配置
# ============================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ============================================
# 部署环境标记
# ============================================
ENV=production
